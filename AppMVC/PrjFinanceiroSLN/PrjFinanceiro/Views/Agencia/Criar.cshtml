@model PrjFinanceiro.Models.Agencia

<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h2>Cadastrar Nova Agência</h2>
        </div>
        <div class="card-body">
            <form action="/Agencia/Criar" method="post">

                <div class="form-group mb-3">
                    <label for="nome">Nome da Agência</label>
                    <input type="text" id="nome" name="nome" class="form-control" required />
                </div>

                <div class="form-group mb-3">
                    <label for="cidade">Cidade</label>
                    <input type="text" id="cidade" name="cidade" class="form-control" required />
                </div>

                <div class="form-group mb-3">
                    <label for="estadoUF">Estado (UF)</label>
                    <input type="text" id="estadoUF" name="estadoUF" class="form-control" maxlength="2" required />
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">Salvar Agência</button>
                    <a href="/Agencia/Index" class="btn btn-secondary">Voltar para a Lista</a>
                </div>

            </form>
        </div>
    </div>
</div>